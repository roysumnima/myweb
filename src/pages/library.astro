---
import { BASE_URL } from '../assets/data/webdetails';
import Layout from '../layouts/Layout.astro';
import Navbar from '../layouts/Navbar.astro';
import { Allprojects } from '../assets/data/projectdetails.js';
---
<Layout>
    <Navbar>
        <div>
            <a href={`${BASE_URL}`}>{"<-"}</a>
        </div>
    </Navbar>
</div>

<div class="gallery" data-projects={JSON.stringify(Allprojects)}>
        {Object.values(Allprojects).map((project) => (
            <div class="gallery-block">
                <a href={`${BASE_URL}/library/${project.id.toLowerCase()}`}>
                    <img src={project.pages[0].imgsrc} alt={project.pages[0].alt}/>
                </a>
            </div>
        ))}

</div>


</Layout>

<script>
   
</script>

<style>
.gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 40vh;
    gap: 2%;
}

.gallery a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    /* background: gold; */
}


.gallery img {;
    max-width: 90%;
    max-height: 90%;
}


</style>