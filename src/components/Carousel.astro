---
import type { Page } from "../assets/types";

const pages: Page[] = Astro.props.pages;
const {width = "auto"} = Astro.props;
const {height = "auto"} = Astro.props;

// import { biophilia } from "../assets/data/projectdetails.js";

// const pages: Page[] = biophilia.pages;
---
<carousel-element data-items={JSON.stringify(pages)}>
    <p>Pages:<p/>
        <!-- <ul>
        {pages.map(page => (
        <li>{page.alt}</li>
        ))}
        </ul> -->
  <button class="carousel-btn" data-prev>{"<"}</button>
  <div carousel-content style={`width: ${width}px; height: ${height}px;`}>
    <img src="err" alt="err"/>
    </div>
  <button class="carousel-btn" data-next>{">"}</button>
</carousel-element>

<script>
    import type { Page } from "../assets/types";
    class Carousel extends HTMLElement {
        current = 0;
        items: Page[] = [];
        // constructor() {
        //     super();
        //     this.current = 0;
        //     this.items = JSON.parse(this.dataset.items || '[]');

        //     this.updateCarousel();
        // }

        connectedCallback() {
        this.items = JSON.parse(this.dataset.items || '[]');
        this.updateCarousel();

        const prevBtn = this.querySelector('[data-prev]');
        if (prevBtn) {
            prevBtn.addEventListener('click', () => this.carouselPrev());
        }

        const nextBtn = this.querySelector('[data-next]');
        if (nextBtn) {
            nextBtn.addEventListener('click', () => this.carouselNext());
        }
        }

        carouselNext() {
            this.current = (this.current + 1) % this.items.length;
            this.updateCarousel();
        }

        carouselPrev() {
            this.current = (this.current - 1 + this.items.length) % this.items.length;
            this.updateCarousel();
        }

        updateCarousel() {
            const img = this.querySelector('.carousel-content img') as HTMLImageElement;
            if (img && this.items[this.current]) {
                img.src = this.items[this.current].imgsrc;
                img.alt = this.items[this.current].alt;
            } else {
                console.error('Carousel image element not found or items array is empty.', this.items, this.current);
            }
        }
        
    }
  customElements.define('carousel-element', Carousel);
  
</script>

<style>
carousel-element {
  display: flex;
  align-items: center;
  gap: 10px;
  background: red;
}
.carousel-btn {
  font-size: 2rem;
  text-decoration: none;
  background-color: white;
  color: black;
  border: none;
  cursor: pointer;
}


.carousel-content {
    display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  background: white;
}

.carousel-content img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
}
</style>