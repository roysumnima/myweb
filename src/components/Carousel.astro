---
const pages = Astro.props.pages;
---
<carousel data-items={pages}>
  <button class="carousel-btn" onclick="carouselPrev()">‹</button>
  <div class="carousel-content" data-imgs={JSON.stringify(pages)}>

    <img src={pages[current].imgsrc} alt={pages[current].alt} />
  </div>
  <button class="carousel-btn" onclick="carouselNext()">›</button>
</carousel>

<script>
    class Carousel extends HTMLElement {
        constructor() {
            super();
            let current = 0;
        }
        connectedCallback() {
            // Read the message from the data attribute.
            const items = this.dataset.items;
        }
  }

  function carouselNext() {
    current = (current + 1) % total;
    updateCarousel();
  }

  function updateCarousel() {
    const img = document.querySelector('.carousel-content img');
    img.src = {items}[current].imgsrc;
    img.alt = {items}[current].alt;
  }
    }

  
</script>

<style>
.carousel {
  display: flex;
  align-items: center;
  gap: 10px;
}
.carousel-btn {
  font-size: 2rem;
  background: none;
  border: none;
  cursor: pointer;
}
.carousel-content img {
  width: 200px;
  height: auto;
  border-radius: 8px;
}
</style>